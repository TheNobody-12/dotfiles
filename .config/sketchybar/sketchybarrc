#!/usr/bin/env sh

: "${CONFIG_DIR:=$HOME/.config/sketchybar}"
PLUGIN_DIR="$CONFIG_DIR/plugins"
THEME_FILE="$HOME/.config/themes/current/shellcolors.sh"

if [ -r "$THEME_FILE" ]; then
  source "$THEME_FILE"
else
  BACKGROUND=0xbb111111
  CLOCK=0xffffffff
  ACTIVE=0xfffe8019
fi

##### Bar Appearance (Floating Pill) #####
bar=(
  position=top
  height=26
  margin=250
  padding_left=12
  padding_right=12
  y_offset=2
  blur_radius=10
  color=0xbb111111
  corner_radius=8
  border_width=2
  border_color=0x44ffffff
  shadow=on
)
sketchybar --bar "${bar[@]}"

##### Defaults #####
FONT="JetBrainsMonoNL Nerd Font"

default=(
  icon.font="$FONT:Bold:12.0"
  label.font="$FONT:Bold:12.0"
  icon.color=0xffebdbb2
  label.color=0xffebdbb2
  icon.padding_left=5
  icon.padding_right=5
  label.padding_left=5
  label.padding_right=5
  background.height=20
  background.corner_radius=3
)
sketchybar --default "${default[@]}"

##### Spaces (Dynamic from Yabai) #####
sketchybar --add event window_change
sketchybar --add event space_windows_change

"$PLUGIN_DIR/space_refresh.sh"

sketchybar --add item space_observer left \
           --set space_observer drawing=off \
                                script="$PLUGIN_DIR/space_refresh.sh" \
           --subscribe space_observer space_change space_windows_change

##### Items #####

# Media: background listener for instant browser updates, fallback poll every 5s
pgrep -f "media.sh listen" >/dev/null || "$PLUGIN_DIR/media.sh" listen &

sketchybar --add item media left \
           --set media icon="󰝚" \
                       label.max_chars=20 \
                       scroll_texts=off \
                       update_freq=5 \
                       padding_left=15 \
                       script="$PLUGIN_DIR/media.sh" \
                       icon.font="JetBrainsMonoNL Nerd Font:Bold:13.0" \
                       background.color=$BACKGROUND \
                       background.drawing=on \
           --subscribe media media_change

# Front App
sketchybar --add item front_app center \
           --set front_app script="$PLUGIN_DIR/front_app.sh" \
                           icon.font="sketchybar-app-font:Regular:14.0" \
                           background.drawing=off \
           --subscribe front_app front_app_switched

# CPU/RAM
sketchybar --add item cpu_ram right \
           --set cpu_ram update_freq=5 \
                         icon="󰍛" \
                         script="$PLUGIN_DIR/cpu_ram.sh" \
                         background.color=$BACKGROUND \
                         background.drawing=on

# Clock
sketchybar --add item clock right \
           --set clock update_freq=10 \
                       icon="󰥔" \
                       script="$PLUGIN_DIR/clock.sh" \
                       background.color=$BACKGROUND \
                       background.drawing=on

# Volume
sketchybar --add item volume right \
           --set volume script="$PLUGIN_DIR/volume.sh" \
                       background.color=$BACKGROUND \
                       background.drawing=on \
           --subscribe volume volume_change

# Battery
sketchybar --add item battery right \
           --set battery update_freq=60 \
                         script="$PLUGIN_DIR/battery.sh" \
                         background.color=$BACKGROUND \
                         background.drawing=on \
           --subscribe battery system_woke power_source_change

sketchybar --update
